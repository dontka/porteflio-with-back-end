<IfModule mod_headers.c>
    # Security Headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    Header set Content-Security-Policy "default-src 'self' http://donatien-kanane.xo.je https://donatien-kanane.xo.je; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://donatien-kanane.xo.je https://donatien-kanane.xo.je; style-src 'self' 'unsafe-inline' http://donatien-kanane.xo.je https://donatien-kanane.xo.je https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' http://donatien-kanane.xo.je https://donatien-kanane.xo.je https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: http://donatien-kanane.xo.je https://donatien-kanane.xo.je https://gravatar.com https://*.gravatar.com https://*.githubusercontent.com https://github-readme-stats.vercel.app https://github-readme-streak-stats.herokuapp.com https://github-readme-activity-graph.vercel.app https://img.shields.io https://skillicons.dev; connect-src 'self' http://donatien-kanane.xo.je https://donatien-kanane.xo.je https://api.github.com https://api.bloggify.net https://github-contributions-api.jogruber.de https://feeds.feedburner.com; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self' http://donatien-kanane.xo.je https://donatien-kanane.xo.je"

    # Cache Control for static assets
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# Compress output
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml image/svg+xml
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(php|md|sql|yml|json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Allow PHP files that are entry points
<FilesMatch "^(index|project|blog|login|register|logout|test_db|sitemap)\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Protect config and includes
<FilesMatch "^(config|Database|functions|handle_comment|handle_edit_comment|handle_like|delete_comment)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Disable directory listing
Options -Indexes

# Set default charset
AddDefaultCharset UTF-8

# URL Rewriting for clean/canonical URLs
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Skip rewriting for existing files and directories (assets, images, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # /blog/{slug} → blog.php?slug={slug}
    RewriteRule ^blog/([a-zA-Z0-9_-]+)/?$ blog.php?slug=$1 [L,QSA]

    # /projet/{encoded-url} → project.php?url={decoded-url}
    RewriteRule ^projet/(.+)/?$ project.php?url=$1 [L,QSA,B]
</IfModule>

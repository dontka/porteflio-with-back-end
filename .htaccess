<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /porteflio-with-back-end/
    
    # Skip rewriting for existing files and directories (assets, static files)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Route all requests through index.php (the Router will handle everything)
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>
